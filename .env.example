# Variáveis de ambiente — copie este arquivo para backend/.env e configure

# Gemini API Key (opcional; usado apenas pelo perfil gemini-native)
GEMINI_API_KEY=sua_chave_gemini_aqui

# Token de admin para endpoints protegidos (POST /reset, etc.)
ADMIN_TOKEN=senha_admin_segura_aqui

# OmniRoute — endpoint local (com /v1 no final)
# Todos os perfis OmniRouter usam este único endpoint; só o modelo muda.
OMNIROUTER_URL=http://192.168.0.15:20128/v1

# API Key para autenticação no OmniRoute (qualquer string serve para proxy local)
OMNIROUTER_API_KEY=omniroute-local

# Perfil default gratuito adotado neste projeto:
# claude-kiro  -> kr/claude-sonnet-4.5

# Origens permitidas no CORS (* = qualquer)
ALLOWED_ORIGINS=*
