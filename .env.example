# Variáveis de ambiente — copie este arquivo para .env e configure
# Execute a partir de backend/: uvicorn main:app --host 0.0.0.0 --port 8001 --reload

# ── Token admin (usado em endpoints protegidos — X-Admin-Token header) ─────────
ADMIN_TOKEN=senha_admin_segura_aqui

# ── IDs autorizados a receber notificações (separados por vírgula) ────────────
AUTHORIZED_IDS=777

# ── OmniRoute — endpoint local (com /v1 no final) ────────────────────────────
# Todos os perfis OmniRouter usam este único endpoint; só o modelo muda.
OMNIROUTER_URL=http://192.168.0.15:20128/v1

# API Key para autenticação no OmniRoute
OMNIROUTER_API_KEY=omniroute-local

# Aliases legados aceitos pelo backend (opcional — use um OU outro):
# OMNIROUTE_URL=http://192.168.0.15:20128/v1
# OMNIROUTE_API_KEY=omniroute-local

# ── Aliases OpenAI-compatible (opcional — para outro endpoint) ────────────────
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=sua_chave_openai_compatible

# ── Gemini (opcional — apenas para perfil gemini-flash) ──────────────────────
GEMINI_API_KEY=sua_chave_gemini_aqui

# ── CORS — origens permitidas (* = qualquer, ou lista separada por vírgula) ──
ALLOWED_ORIGINS=*
